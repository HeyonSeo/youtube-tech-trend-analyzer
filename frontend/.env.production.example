# =============================================================================
# TechPulse Frontend — Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in the values.
# For Vercel deployments, set these in the Vercel Dashboard > Settings > Environment Variables.

# -----------------------------------------------------------------------------
# Backend API URL (REQUIRED)
# -----------------------------------------------------------------------------
# The full URL of the deployed backend (Railway/Render).
# Used for server-side requests and Vercel rewrites.
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
BACKEND_URL=https://your-backend.up.railway.app

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# A random secret for signing JWT tokens. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# The canonical URL of the frontend deployment.
NEXTAUTH_URL=https://your-app.vercel.app

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Vercel Cron Secret (RECOMMENDED)
# -----------------------------------------------------------------------------
# Protects the /api/cron/analyze endpoint from unauthorized access.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
