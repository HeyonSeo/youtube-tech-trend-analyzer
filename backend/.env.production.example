# =============================================================================
# TechPulse Backend — Production Environment Variables
# =============================================================================
# For Railway deployments, set these in the Railway Dashboard > Variables.
# For Render deployments, set these in the Render Dashboard > Environment.

# -----------------------------------------------------------------------------
# YouTube Data API (REQUIRED)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key

# -----------------------------------------------------------------------------
# CORS (REQUIRED)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Must include your Vercel frontend URL.
CORS_ORIGINS=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Supabase Database (OPTIONAL — enables trend tracking & persistence)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Resend Email (OPTIONAL — enables email reports)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
REPORT_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
YOUTUBE_API_TIMEOUT=15

# -----------------------------------------------------------------------------
# Custom Search Queries (OPTIONAL)
# -----------------------------------------------------------------------------
# Path to a JSON file with custom search queries
# CUSTOM_QUERIES_FILE=/app/custom_queries.json
